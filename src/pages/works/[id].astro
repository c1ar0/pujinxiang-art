---
import { works, getWork } from '../../data/works';

export function getStaticPaths() {
  return works.map((work) => ({ params: { id: work.id } }));
}

const { id } = Astro.params;
const work = getWork(id!);
if (!work) {
  return Astro.redirect('/');
}
const related = works.filter((item) => item.category === work.category && item.id !== work.id).slice(0, 3);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={work.description} />
    <title>{work.title} · 普锦湘作品集</title>
  </head>
  <body>
    <div class="ambient" aria-hidden="true"><span class="orb orb-a"></span><span class="orb orb-b"></span></div>
    <header class="nav-wrap">
      <nav class="glass nav">
        <a class="brand" href="/"><span class="brand-dot"></span><span>普锦湘</span></a>
        <a class="back" href="/#archive">返回作品集</a>
      </nav>
    </header>

    <main>
      <section class="section hero-detail">
        <div class="title-block">
          <p class="eyebrow">{work.category} · {work.year}</p>
          <h1>{work.title}</h1>
          <p>{work.summary}</p>
        </div>
        <div class="glass image-stage">
          <button class="image-button" data-full={work.image} data-title={work.title} aria-label={`放大查看 ${work.title}`}>
            <img src={work.image} alt={work.title} />
          </button>
        </div>
      </section>

      <section class="section detail-grid">
        <article class="glass essay">
          <p class="eyebrow">Design Statement</p>
          <h2>作品说明</h2>
          <p>{work.description}</p>
          <p>作为美术设计专业作品，该项目重点不只是最终图像，而是围绕主题提炼、视觉秩序、材料或载体关系所形成的完整表达。页面中的说明基于课程方向与图像类别整理，后续可继续替换为更准确的创作背景、草图过程和老师评语。</p>
        </article>
        <aside class="glass meta">
          <div>
            <span>分类</span>
            <strong>{work.category}</strong>
          </div>
          <div>
            <span>画面方向</span>
            <strong>{work.orientation}</strong>
          </div>
          <div>
            <span>工具 / 技法</span>
            <div class="chips">{work.tools.map((tool) => <em>{tool}</em>)}</div>
          </div>
        </aside>
      </section>

      <section class="section notes">
        <div class="section-head">
          <p class="eyebrow">Design Notes</p>
          <h2>设计要点</h2>
        </div>
        <div class="note-grid">
          {work.designNotes.map((note, index) => (
            <article class="glass note-card">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <p>{note}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section related">
        <div class="section-head compact">
          <div>
            <p class="eyebrow">Related</p>
            <h2>同类作品</h2>
          </div>
          <a href="/#archive">查看全部 →</a>
        </div>
        <div class="related-grid">
          {related.map((item) => (
            <a class="glass related-card" href={`/works/${item.id}/`}>
              <img src={item.image} alt={item.title} loading="lazy" />
              <div><span>{item.category}</span><strong>{item.title}</strong></div>
            </a>
          ))}
        </div>
      </section>
    </main>

    <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="图片预览">
      <button class="lightbox-close" id="lightboxClose" aria-label="关闭预览">×</button>
      <img id="lightboxImage" src="" alt="" />
      <p id="lightboxTitle"></p>
    </div>

    <script>
      const lightbox = document.getElementById('lightbox');
      const lightboxImage = document.getElementById('lightboxImage');
      const lightboxTitle = document.getElementById('lightboxTitle');
      const close = document.getElementById('lightboxClose');
      document.querySelectorAll('.image-button').forEach((button) => {
        button.addEventListener('click', () => {
          lightboxImage.src = button.dataset.full;
          lightboxImage.alt = button.dataset.title;
          lightboxTitle.textContent = button.dataset.title;
          lightbox.setAttribute('aria-hidden', 'false');
          document.body.classList.add('no-scroll');
        });
      });
      function closeLightbox() { lightbox.setAttribute('aria-hidden', 'true'); document.body.classList.remove('no-scroll'); lightboxImage.src = ''; }
      close.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (event) => { if (event.target === lightbox) closeLightbox(); });
      window.addEventListener('keydown', (event) => { if (event.key === 'Escape') closeLightbox(); });
    </script>
  </body>
</html>

<style>
  :root{color-scheme:light;--bg:#f5f5f7;--ink:#1d1d1f;--muted:rgba(29,29,31,.68);--faint:rgba(29,29,31,.46);--blue:#0071e3;--stroke:rgba(255,255,255,.78);--line:rgba(29,29,31,.09);--shadow:0 28px 90px rgba(80,88,110,.18);font-family:system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}*{box-sizing:border-box}html{background:var(--bg)}body{margin:0;min-height:100vh;color:var(--ink);background:linear-gradient(180deg,#fbfbfd 0%,#f5f5f7 50%,#eef3fb 100%);letter-spacing:-.374px}body.no-scroll{overflow:hidden}a{text-decoration:none;color:inherit}img{display:block;width:100%;height:auto}.ambient{position:fixed;inset:0;z-index:-1;overflow:hidden;pointer-events:none}.orb{position:absolute;width:38rem;height:38rem;border-radius:999px;filter:blur(46px);opacity:.42}.orb-a{left:-12rem;top:8rem;background:rgba(41,151,255,.24)}.orb-b{right:-14rem;top:26rem;background:rgba(255,182,193,.32)}.glass{border:1px solid var(--stroke);background:linear-gradient(135deg,rgba(255,255,255,.82),rgba(255,255,255,.46));box-shadow:var(--shadow),inset 0 1px 0 rgba(255,255,255,.9);backdrop-filter:saturate(180%) blur(30px);-webkit-backdrop-filter:saturate(180%) blur(30px)}.nav-wrap{position:sticky;top:0;z-index:20;padding:14px 20px}.nav{width:min(980px,100%);height:48px;margin:0 auto;border-radius:980px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;font-size:13px}.brand{display:flex;align-items:center;gap:8px;font-weight:650}.brand-dot{width:9px;height:9px;border-radius:99px;background:var(--blue);box-shadow:0 0 20px rgba(0,113,227,.55)}.back{color:var(--blue);font-weight:600}.section{width:min(1160px,calc(100% - 40px));margin:0 auto;padding:86px 0}.hero-detail{display:grid;grid-template-columns:.78fr 1.22fr;gap:34px;align-items:center}.eyebrow{margin:0 0 18px;color:var(--blue);font-size:13px;font-weight:700;letter-spacing:.11em;text-transform:uppercase}h1,h2,h3,p{margin-top:0}h1{font-size:clamp(46px,7vw,96px);line-height:.95;letter-spacing:-.07em;margin-bottom:24px}h2{font-size:clamp(32px,4vw,56px);line-height:1;letter-spacing:-.055em}.title-block p,.essay p{color:var(--muted);font-size:18px;line-height:1.7}.image-stage{border-radius:42px;padding:18px}.image-button{display:block;width:100%;padding:0;border:0;background:transparent;cursor:zoom-in}.image-stage img{max-height:72vh;object-fit:contain;border-radius:28px;background:#f2f2f4}.detail-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:22px;padding-top:20px}.essay,.meta{border-radius:36px;padding:34px}.meta{display:grid;gap:24px}.meta span,.related-card span{display:block;color:var(--faint);font-size:13px;margin-bottom:8px}.meta strong{font-size:20px}.chips{display:flex;flex-wrap:wrap;gap:9px}.chips em{font-style:normal;border-radius:999px;padding:8px 10px;background:rgba(255,255,255,.55);border:1px solid var(--line);font-size:13px}.section-head{margin-bottom:28px}.compact{display:flex;justify-content:space-between;align-items:end;gap:20px}.compact a{color:var(--blue);font-weight:650}.note-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.note-card{border-radius:30px;padding:26px}.note-card span{color:var(--blue);font-weight:750}.note-card p{font-size:18px;line-height:1.55;color:var(--muted);margin:16px 0 0}.related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.related-card{border-radius:30px;overflow:hidden;transition:transform .24s ease}.related-card:hover{transform:translateY(-5px)}.related-card img{height:240px;object-fit:cover;background:#f2f2f4}.related-card div{padding:16px}.related-card strong{font-size:18px}.lightbox{position:fixed;inset:0;z-index:100;display:none;align-items:center;justify-content:center;padding:72px 24px 36px;background:rgba(245,245,247,.72);backdrop-filter:blur(34px) saturate(160%);-webkit-backdrop-filter:blur(34px) saturate(160%)}.lightbox[aria-hidden="false"]{display:flex}.lightbox img{max-width:min(1100px,92vw);max-height:78vh;width:auto;border-radius:24px;box-shadow:0 30px 100px rgba(0,0,0,.28)}.lightbox p{position:absolute;bottom:22px;margin:0;color:var(--muted);font-weight:600}.lightbox-close{position:absolute;top:22px;right:24px;width:46px;height:46px;border-radius:999px;border:1px solid rgba(29,29,31,.08);background:rgba(255,255,255,.72);font-size:30px;line-height:1;cursor:pointer;color:var(--ink)}@media(max-width:900px){.section{width:min(100% - 28px,1160px);padding:64px 0}.hero-detail,.detail-grid,.note-grid,.related-grid{grid-template-columns:1fr}h1{font-size:clamp(42px,13vw,72px)}.compact{display:block}}
</style>
