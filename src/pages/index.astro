---
import { works, featuredWorks } from '../data/works';

const profile = {
  name: '普锦湘',
  role: '工艺美术 / 视觉设计 / 文创产品设计',
  intro: '工艺美术专业本科毕业，关注传统工艺、地域文化与现代视觉设计之间的连接。作品涵盖文创产品设计、竹木工艺技法、平面视觉与手工材料实践。',
  email: '2449259696@qq.com',
  phone: '15331559668',
  location: '云南昆明',
};

const highlights = ['工艺美术专业', '文创产品设计', '竹木工艺技法', '视觉设计执行'];

const experience = [
  {
    time: '2025.08 - 2026.05',
    org: '红塔区春潮高科图文广告制作中心',
    role: '设计师助理',
    desc: '协助完成海报、宣传单页、活动物料、新媒体配图等视觉设计初稿与优化；参与图片精修、版式布局、字体搭配、色彩调整，并对接印刷制作文件。',
  },
  {
    time: '2024.09 - 2024.11',
    org: '红塔区春潮高科图文广告制作中心',
    role: '设计师助理',
    desc: '参与图文广告设计与优化，独立完成基础图片处理、海报元素设计和宣传册排版，提升团队协作与设计执行能力。',
  },
];

const awards = ['全国大学生广告艺术大赛优秀奖', '昭通学院新媒体协会会徽设计比赛一等奖', '国家励志奖学金', '昭通学院“三好学生”', '昭通学院“优秀毕业生”'];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={`${profile.name} 的工艺美术与视觉设计作品集`} />
    <title>{profile.name} · 作品集</title>
  </head>
  <body>
    <div class="ambient" aria-hidden="true">
      <span class="orb orb-a"></span>
      <span class="orb orb-b"></span>
      <span class="orb orb-c"></span>
      <span class="grain"></span>
    </div>

    <header class="nav-wrap">
      <nav class="glass nav" aria-label="主导航">
        <a class="brand" href="#top"><span class="brand-dot"></span><span>{profile.name}</span></a>
        <div class="nav-links">
          <a href="#work">作品</a>
          <a href="#about">关于</a>
          <a href="#archive">归档</a>
          <a href="#contact">联系</a>
        </div>
      </nav>
    </header>

    <main id="top">
      <section class="hero section">
        <p class="eyebrow">Craft · Visual · Cultural Design</p>
        <h1>以工艺质感，塑造有温度的视觉表达。</h1>
        <p class="hero-copy">{profile.intro}</p>
        <div class="hero-actions">
          <a class="button primary" href="#work">查看精选作品</a>
          <a class="button ghost" href={`mailto:${profile.email}`}>联系我</a>
        </div>
        <div class="hero-panel glass-strong">
          <div>
            <span class="panel-label">Portfolio Direction</span>
            <strong>{profile.role}</strong>
          </div>
          <div class="panel-grid">{highlights.map((item) => <span>{item}</span>)}</div>
        </div>
      </section>

      <section class="section" id="work">
        <div class="section-head centered">
          <p class="eyebrow">Selected Works</p>
          <h2>精选作品</h2>
          <p>以浅色 Apple Liquid Glass 风格呈现课程作品。每张图片都可以点击放大，也可以进入详情页查看设计说明。</p>
        </div>
        <div class="featured-grid">
          {featuredWorks.map((work) => (
            <article class={`glass work-card featured-card ${work.orientation === '纵向' ? 'portrait' : ''}`}>
              <button class="image-button" data-full={work.image} data-title={work.title} aria-label={`放大查看 ${work.title}`}>
                <img src={work.image} alt={work.title} loading="lazy" />
              </button>
              <div class="work-info">
                <span>{work.category}</span>
                <h3>{work.title}</h3>
                <p>{work.summary}</p>
                <a class="text-link" href={`/works/${work.id}/`}>查看详情 →</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section split" id="about">
        <div>
          <p class="eyebrow">About</p>
          <h2>从传统材料，到现代视觉系统。</h2>
        </div>
        <div class="glass card about-card">
          <p>本科就读于昭通学院工艺美术专业，主修广告创意设计、文创产品设计、现代木艺、竹木工艺技法、商业摄影、包装设计、雕刻工艺等课程。作品集希望呈现“材料感、文化性、视觉秩序”三者之间的关系。</p>
          <div class="skill-list">
            {['文创产品设计', '平面视觉设计', '竹木工艺', '海报与宣传物料', '图片精修', '版式排版', '商业摄影', '包装设计'].map((skill) => <span>{skill}</span>)}
          </div>
        </div>
      </section>

      <section class="section" id="archive">
        <div class="section-head compact">
          <div>
            <p class="eyebrow">Archive</p>
            <h2>作品归档</h2>
          </div>
          <p>{works.length} 件课程与实践作品</p>
        </div>
        <div class="masonry">
          {works.map((work) => (
            <figure class="glass archive-card">
              <button class="image-button" data-full={work.image} data-title={work.title} aria-label={`放大查看 ${work.title}`}>
                <img src={work.image} alt={work.title} loading="lazy" />
              </button>
              <figcaption>
                <span>{work.category}</span>
                <strong>{work.title}</strong>
                <a href={`/works/${work.id}/`}>详情</a>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>

      <section class="section experience" id="experience">
        <div class="section-head compact">
          <div>
            <p class="eyebrow">Experience</p>
            <h2>经历与荣誉</h2>
          </div>
        </div>
        <div class="experience-grid">
          <div class="glass timeline">
            {experience.map((item) => (
              <article>
                <span>{item.time}</span>
                <h3>{item.org}</h3>
                <strong>{item.role}</strong>
                <p>{item.desc}</p>
              </article>
            ))}
          </div>
          <div class="glass awards">
            <h3>荣誉奖项</h3>
            <ul>{awards.map((award) => <li>{award}</li>)}</ul>
          </div>
        </div>
      </section>

      <section class="section contact" id="contact">
        <div class="glass-strong contact-panel">
          <p class="eyebrow">Contact</p>
          <h2>期待与文创、视觉设计、工艺实践相关的机会。</h2>
          <div class="contact-row">
            <a class="button primary" href={`mailto:${profile.email}`}>{profile.email}</a>
            <a class="button ghost" href={`tel:${profile.phone}`}>{profile.phone}</a>
            <span>{profile.location}</span>
          </div>
        </div>
      </section>
    </main>

    <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="图片预览">
      <button class="lightbox-close" id="lightboxClose" aria-label="关闭预览">×</button>
      <img id="lightboxImage" src="" alt="" />
      <p id="lightboxTitle"></p>
    </div>

    <script>
      const lightbox = document.getElementById('lightbox');
      const lightboxImage = document.getElementById('lightboxImage');
      const lightboxTitle = document.getElementById('lightboxTitle');
      const close = document.getElementById('lightboxClose');
      document.querySelectorAll('.image-button').forEach((button) => {
        button.addEventListener('click', () => {
          lightboxImage.src = button.dataset.full;
          lightboxImage.alt = button.dataset.title;
          lightboxTitle.textContent = button.dataset.title;
          lightbox.setAttribute('aria-hidden', 'false');
          document.body.classList.add('no-scroll');
        });
      });
      function closeLightbox() {
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('no-scroll');
        lightboxImage.src = '';
      }
      close.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (event) => { if (event.target === lightbox) closeLightbox(); });
      window.addEventListener('keydown', (event) => { if (event.key === 'Escape') closeLightbox(); });
    </script>
  </body>
</html>

<style>
  :root { color-scheme: light; --bg:#f5f5f7; --paper:#fff; --ink:#1d1d1f; --muted:rgba(29,29,31,.68); --faint:rgba(29,29,31,.46); --blue:#0071e3; --blue2:#2997ff; --glass:rgba(255,255,255,.62); --stroke:rgba(255,255,255,.78); --line:rgba(29,29,31,.09); --shadow:0 28px 90px rgba(80,88,110,.18); font-family:system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; }
  *{box-sizing:border-box} html{scroll-behavior:smooth;background:var(--bg)} body{margin:0;min-height:100vh;color:var(--ink);background:linear-gradient(180deg,#fbfbfd 0%,#f5f5f7 42%,#eef3fb 100%);overflow-x:hidden;letter-spacing:-.374px} body.no-scroll{overflow:hidden} a{color:inherit;text-decoration:none} img{display:block;width:100%;height:auto}.ambient{position:fixed;inset:0;pointer-events:none;overflow:hidden;z-index:-1}.orb{position:absolute;width:38rem;height:38rem;border-radius:999px;filter:blur(46px);opacity:.5;animation:float 18s ease-in-out infinite alternate}.orb-a{left:-12rem;top:6rem;background:rgba(41,151,255,.24)}.orb-b{right:-14rem;top:18rem;background:rgba(255,182,193,.32);animation-delay:-5s}.orb-c{left:32%;bottom:-20rem;background:rgba(190,210,255,.38);animation-delay:-9s}.grain{position:absolute;inset:0;opacity:.42;background-image:radial-gradient(rgba(255,255,255,.9) 1px,transparent 1px);background-size:18px 18px;mask-image:linear-gradient(to bottom,black,transparent)}
  .glass,.glass-strong{border:1px solid var(--stroke);background:linear-gradient(135deg,rgba(255,255,255,.82),rgba(255,255,255,.46));box-shadow:var(--shadow),inset 0 1px 0 rgba(255,255,255,.9);backdrop-filter:saturate(180%) blur(30px);-webkit-backdrop-filter:saturate(180%) blur(30px)}.glass-strong{background:linear-gradient(135deg,rgba(255,255,255,.92),rgba(255,255,255,.56))}.nav-wrap{position:sticky;top:0;z-index:20;padding:14px max(20px,env(safe-area-inset-left))}.nav{width:min(980px,100%);height:48px;margin:0 auto;border-radius:980px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;font-size:12px;color:rgba(29,29,31,.78)}.brand{display:flex;align-items:center;gap:8px;font-weight:650}.brand-dot{width:9px;height:9px;border-radius:99px;background:var(--blue);box-shadow:0 0 20px rgba(0,113,227,.55)}.nav-links{display:flex;gap:22px;color:rgba(29,29,31,.62)}.nav-links a:hover{color:var(--ink)}
  .section{width:min(1160px,calc(100% - 40px));margin:0 auto;padding:108px 0}.hero{min-height:calc(100vh - 76px);display:grid;align-content:center;justify-items:center;text-align:center;padding-top:70px}.eyebrow{margin:0 0 18px;color:var(--blue);font-size:13px;font-weight:700;letter-spacing:.11em;text-transform:uppercase}h1,h2,h3,p{margin-top:0}h1{max-width:1000px;margin-bottom:24px;font-size:clamp(52px,8.6vw,112px);line-height:.94;letter-spacing:-.075em;font-weight:730}h2{font-size:clamp(36px,5vw,68px);line-height:1;letter-spacing:-.06em;font-weight:700}h3{font-size:26px;line-height:1.1;letter-spacing:-.04em;margin-bottom:10px}.hero-copy,.section-head p{max-width:760px;color:var(--muted);font-size:clamp(17px,2vw,22px);line-height:1.58}.centered{text-align:center;display:grid;justify-items:center}.hero-actions{display:flex;flex-wrap:wrap;justify-content:center;gap:14px;margin-top:12px}.button{min-height:44px;display:inline-flex;align-items:center;justify-content:center;border-radius:980px;padding:12px 21px;font-size:17px;transition:transform .24s ease,box-shadow .24s ease}.button:hover{transform:translateY(-2px)}.primary{background:var(--blue);color:#fff;box-shadow:0 12px 34px rgba(0,113,227,.25)}.ghost{border:1px solid rgba(29,29,31,.12);color:var(--ink);background:rgba(255,255,255,.52)}.text-link{display:inline-flex;margin-top:8px;color:var(--blue);font-weight:600}.hero-panel{width:min(820px,100%);margin-top:64px;border-radius:34px;padding:22px;display:grid;grid-template-columns:.9fr 1.4fr;gap:20px;text-align:left}.panel-label,.work-info span,figcaption span,.timeline span{display:block;color:var(--faint);font-size:13px;margin-bottom:8px}.hero-panel strong{font-size:24px;letter-spacing:-.04em}.panel-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}.panel-grid span,.skill-list span{border-radius:980px;padding:9px 11px;color:rgba(29,29,31,.74);background:rgba(255,255,255,.55);border:1px solid rgba(29,29,31,.08);text-align:center;font-size:13px}
  .section-head{margin-bottom:38px}.compact{display:flex;align-items:end;justify-content:space-between;gap:24px}.featured-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.work-card,.archive-card{border-radius:36px;overflow:hidden;transition:transform .28s ease,border-color .28s ease}.work-card:hover,.archive-card:hover{transform:translateY(-6px);border-color:#fff}.image-button{display:block;width:100%;padding:0;border:0;background:transparent;cursor:zoom-in}.featured-card img{height:310px;object-fit:cover;background:#f2f2f4}.featured-card.portrait img{height:430px}.work-info{padding:22px}.work-info p{color:var(--muted);line-height:1.66}.split{display:grid;grid-template-columns:.85fr 1fr;gap:56px;align-items:start}.card,.contact-panel,.timeline,.awards{border-radius:36px}.about-card{padding:34px}.about-card p,.timeline p{color:var(--muted);line-height:1.72;font-size:17px}.skill-list{display:flex;flex-wrap:wrap;gap:10px;margin-top:28px}.masonry{columns:3 260px;column-gap:20px}.archive-card{break-inside:avoid;margin:0 0 20px}.archive-card img{background:#f2f2f4}figcaption{padding:16px 18px 18px;display:grid;gap:5px}figcaption strong{font-size:17px}figcaption a{color:var(--blue);font-size:14px;font-weight:600}.experience-grid{display:grid;grid-template-columns:1.35fr .85fr;gap:20px}.timeline,.awards{padding:30px}.timeline article+article{margin-top:26px;padding-top:26px;border-top:1px solid var(--line)}.timeline strong{display:inline-block;margin-bottom:10px}.awards ul{padding-left:18px;margin:18px 0 0;color:var(--muted);line-height:1.9}.contact{padding-bottom:140px}.contact-panel{padding:clamp(30px,6vw,64px);text-align:center}.contact-panel h2{max-width:820px;margin-left:auto;margin-right:auto}.contact-row{display:flex;gap:18px;justify-content:center;align-items:center;flex-wrap:wrap;margin-top:30px;color:var(--muted)}
  .lightbox{position:fixed;inset:0;z-index:100;display:none;align-items:center;justify-content:center;padding:72px 24px 36px;background:rgba(245,245,247,.72);backdrop-filter:blur(34px) saturate(160%);-webkit-backdrop-filter:blur(34px) saturate(160%)}.lightbox[aria-hidden="false"]{display:flex}.lightbox img{max-width:min(1100px,92vw);max-height:78vh;width:auto;border-radius:24px;box-shadow:0 30px 100px rgba(0,0,0,.28)}.lightbox p{position:absolute;bottom:22px;margin:0;color:var(--muted);font-weight:600}.lightbox-close{position:absolute;top:22px;right:24px;width:46px;height:46px;border-radius:999px;border:1px solid rgba(29,29,31,.08);background:rgba(255,255,255,.72);font-size:30px;line-height:1;cursor:pointer;color:var(--ink)}
  @keyframes float{from{transform:translate3d(0,0,0) scale(1)}to{transform:translate3d(42px,-36px,0) scale(1.08)}}@media (prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;scroll-behavior:auto!important;transition:none!important}}@media(max-width:900px){.section{width:min(100% - 28px,1160px);padding:76px 0}.hero{text-align:left;justify-items:stretch}.hero-actions{justify-content:flex-start}.hero-panel,.split,.featured-grid,.experience-grid{grid-template-columns:1fr}.panel-grid{grid-template-columns:repeat(2,1fr)}h1{font-size:clamp(46px,14vw,76px)}.compact{display:block}.featured-card.portrait img,.featured-card img{height:auto;max-height:none}}@media(max-width:560px){.nav-links{gap:12px}.nav-links a:nth-child(3){display:none}.masonry{columns:1}.lightbox{padding-left:12px;padding-right:12px}}
</style>
